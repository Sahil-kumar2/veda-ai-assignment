NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/veda_ai
MONGO_DB_NAME=veda_ai
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2
MONGO_SERVER_SELECTION_TIMEOUT_MS=8000
MONGO_SOCKET_TIMEOUT_MS=45000

# Use REDIS_URL in production (Upstash / managed Redis)
REDIS_URL=redis://localhost:6379

# Optional host/port fallback for local development
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
CORS_ORIGIN=http://localhost:5173

# Groq (required)
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
